<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TextUpsideDown.MainPage">

    <StackLayout>
        <Label 
            Font="26" 
            Text="Введённый текст" 
            Margin="20, 20, 0, 10"/>
        <Editor 
            x:Name="input"
            IsSpellCheckEnabled="false" 
            BackgroundColor="#" 
            Margin="20, 0, 20, 0" 
            HeightRequest="200"/>
        <Label 
            Font="26" 
            Text="Перевернутый текст" 
            Margin="20, 20, 0, 10"/>
        <Editor 
            x:Name="output"
            IsSpellCheckEnabled="false" 
            BackgroundColor="#" 
            Margin="20, 0, 20, 0" 
            HeightRequest="200"/>
        <Button
            Font="20" 
            Text="Перевернуть" 
            Margin="20, 0, 20, 0" 
            HeightRequest="60"
            Pressed="OnButtonPressed"
            ></Button>
    </StackLayout>

</ContentPage>
